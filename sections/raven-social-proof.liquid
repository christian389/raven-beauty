{% liquid
  assign widths = '240, 360, 480, 640, 800, 960, 1200'
  assign sizes = '(min-width: 990px) calc((min(1280px, 100vw) - (var(--rsp-gap) * (var(--rsp-columns) - 1))) / var(--rsp-columns)), (min-width: 750px) calc((100vw - (var(--page-margin) * 2) - (var(--rsp-gap) * (var(--rsp-columns-tablet) - 1))) / var(--rsp-columns-tablet)), calc((100vw - (var(--page-margin) * 2) - (var(--rsp-gap) * (var(--rsp-columns-mobile) - 1))) / var(--rsp-columns-mobile))'
%}

<section
  id="RavenSocialProof-{{ section.id }}"
  class="raven-social-proof color-{{ section.settings.color_scheme }}"
  style="
    --rsp-gap: {{ section.settings.grid_gap }}px;
    --rsp-radius: {{ section.settings.card_radius }}px;
    --rsp-columns: {{ section.settings.columns_desktop }};
    --rsp-columns-tablet: {{ section.settings.columns_tablet }};
    --rsp-columns-mobile: {{ section.settings.columns_mobile }};
    --rsp-heading-color: {{ section.settings.heading_color }};
    --rsp-text-color: {{ section.settings.text_color }};
    --rsp-max-width: {{ section.settings.max_width }}px;
  "
>
  <div
    class="raven-social-proof__container spacing-style section section--page-width"
    style="{% render 'spacing-style', settings: section.settings %}"
  >
    <div class="raven-social-proof__header">
      {% if section.settings.heading != blank %}
        <h2 class="raven-social-proof__heading">
          {{ section.settings.heading | escape }}
        </h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="raven-social-proof__text rte">
          {{ section.settings.text }}
        </div>
      {% endif %}
    </div>

    <div class="raven-social-proof__grid" role="list">
      {% for block in section.blocks %}
        {% liquid
          assign tile_tag = 'div'
          if block.settings.link != blank
            assign tile_tag = 'a'
          endif

          assign fallback_index = forloop.index | modulo: 6
          if fallback_index == 0
            assign fallback_index = 6
          endif
          assign fallback_asset = 'raven/social-proof/social-' | append: fallback_index | append: '.png'
        %}

        <{{ tile_tag }}
          class="raven-social-proof__tile"
          role="listitem"
          {% if tile_tag == 'a' %}
            href="{{ block.settings.link }}"
          {% endif %}
          {{ block.shopify_attributes }}
        >
          {% if block.settings.image != blank %}
            {{
              block.settings.image
              | image_url: width: 1200
              | image_tag:
                widths: widths,
                sizes: sizes,
                class: 'raven-social-proof__image',
                loading: 'lazy',
                alt: ''
            }}
          {% else %}
            <img
              class="raven-social-proof__image"
              src="{{ fallback_asset | asset_url }}"
              loading="lazy"
              alt=""
            >
          {% endif %}
        </{{ tile_tag }}>
      {% endfor %}

      {% if section.blocks.size == 0 %}
        {% for i in (1..6) %}
          <div class="raven-social-proof__tile" role="listitem">
            <img
              class="raven-social-proof__image"
              src="{{ 'raven/social-proof/social-' | append: i | append: '.png' | asset_url }}"
              loading="lazy"
              alt=""
            >
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .raven-social-proof {
    --raven-font-heading: "Noto Serif", ui-serif, Georgia, "Times New Roman", Times, serif;
    --raven-font-body: "Noto Sans", ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, Arial, sans-serif;
  }

  .raven-social-proof__container {
    max-width: var(--rsp-max-width);
    width: 100%;
    margin-inline: auto;
    justify-self: center;
  }

  .raven-social-proof__header {
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: center;
    text-align: center;
    margin-bottom: 40px;
  }

  .raven-social-proof__heading {
    margin: 0;
    color: var(--rsp-heading-color);
    font-family: var(--raven-font-heading);
    font-weight: 700;
    font-size: 30px;
    line-height: 36px;
    text-wrap: balance;
  }

  .raven-social-proof__text {
    color: var(--rsp-text-color);
    font-family: var(--raven-font-body);
    font-size: 16px;
    line-height: 24px;
  }

  .raven-social-proof__text > :first-child {
    margin-top: 0;
  }

  .raven-social-proof__text > :last-child {
    margin-bottom: 0;
  }

  .raven-social-proof__grid {
    display: grid;
    gap: var(--rsp-gap);
    grid-template-columns: repeat(var(--rsp-columns-mobile), minmax(0, 1fr));
  }

  @media screen and (min-width: 750px) {
    .raven-social-proof__grid {
      grid-template-columns: repeat(var(--rsp-columns-tablet), minmax(0, 1fr));
    }
  }

  @media screen and (min-width: 990px) {
    .raven-social-proof__grid {
      grid-template-columns: repeat(var(--rsp-columns), minmax(0, 1fr));
    }
  }

  .raven-social-proof__tile {
    position: relative;
    border-radius: var(--rsp-radius);
    overflow: clip;
    aspect-ratio: 1 / 1;
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .raven-social-proof__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media screen and (max-width: 749px) {
    .raven-social-proof__header {
      margin-bottom: 24px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Raven Social Proof",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Følg vores univers"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Del dine skønhedsmomenter med #RavenBeauty</p>"
    },
    {
      "type": "header",
      "content": "Grid"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width",
      "min": 320,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 1280
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Gap",
      "min": 0,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Corner radius",
      "min": 0,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns (desktop)",
      "options": [
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" },
        { "value": "6", "label": "6" }
      ],
      "default": "6"
    },
    {
      "type": "select",
      "id": "columns_tablet",
      "label": "Columns (tablet)",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns (mobile)",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" }
      ],
      "default": "2"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "alpha": true,
      "default": "#0F172A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "alpha": true,
      "default": "#64748B"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "Left padding",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "Right padding",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Raven Social Proof",
      "category": "Raven Beauty",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}

