{% liquid
  assign widths = '375, 550, 750, 990, 1200, 1500, 1800, 2100'
  assign sizes = '(min-width: 990px) calc((100vw - (var(--page-margin) * 2) - (var(--rcat-gap) * 3)) / 4), (min-width: 750px) calc((100vw - (var(--page-margin) * 2) - var(--rcat-gap)) / 2), calc(100vw - (var(--page-margin) * 2))'
%}

<section
  id="RavenCategories-{{ section.id }}"
  class="raven-categories color-{{ section.settings.color_scheme }}"
  style="
    --rcat-gap: {{ section.settings.grid_gap }}px;
    --rcat-card-gap: {{ section.settings.card_gap }}px;
    --rcat-radius: {{ section.settings.card_radius }}px;
    --rcat-image-height: {{ section.settings.image_height }}px;
    --rcat-image-overlay: {{ section.settings.image_overlay }};
    --rcat-title-color: {{ section.settings.title_color }};
    --rcat-link-color: {{ section.settings.link_color }};
    --rcat-image-surface: {{ section.settings.image_surface }};
  "
>
  <div
    class="raven-categories__container spacing-style section"
    style="{% render 'spacing-style', settings: section.settings %}"
  >
    <header class="raven-categories__header">
      {% if section.settings.heading != blank %}
        <h2 class="raven-categories__heading">
          {{ section.settings.heading | escape }}
        </h2>
      {% endif %}

      {% if section.settings.show_view_all and section.settings.view_all_label != blank %}
        <a
          class="raven-categories__view-all"
          {% if section.settings.view_all_link == blank %}
            role="link"
            aria-disabled="true"
          {% else %}
            href="{{ section.settings.view_all_link }}"
          {% endif %}
        >
          <span class="raven-categories__view-all-label">{{ section.settings.view_all_label | escape }}</span>
          <span class="raven-categories__view-all-icon svg-wrapper" aria-hidden="true">
            {{ 'icon-chevron-right.svg' | inline_asset_content }}
          </span>
        </a>
      {% endif %}
    </header>

    <div class="raven-categories__grid" role="list">
      {% for block in section.blocks %}
        {% liquid
          assign card_tag = 'div'
          if block.settings.link != blank
            assign card_tag = 'a'
          endif

          assign fallback_key = block.settings.title | default: '' | handleize
          assign fallback_asset = 'raven/categories/' | append: fallback_key | append: '.png'
        %}

        <{{ card_tag }}
          class="raven-categories__card"
          role="listitem"
          {% if card_tag == 'a' %}
            href="{{ block.settings.link }}"
          {% endif %}
          {{ block.shopify_attributes }}
        >
          <div class="raven-categories__media">
            <div class="raven-categories__media-surface" aria-hidden="true"></div>

            {% if block.settings.image != blank %}
              {{
                block.settings.image
                | image_url: width: 2100
                | image_tag:
                  widths: widths,
                  sizes: sizes,
                  class: 'raven-categories__image',
                  loading: 'lazy',
                  alt: ''
              }}
            {% elsif fallback_key != blank %}
              <img
                class="raven-categories__image"
                src="{{ fallback_asset | asset_url }}"
                loading="lazy"
                alt=""
              >
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'raven-categories__image' }}
            {% endif %}

            {% if section.settings.enable_image_overlay %}
              <div class="raven-categories__overlay" aria-hidden="true"></div>
            {% endif %}
          </div>

          {% if block.settings.title != blank %}
            <div class="raven-categories__title">
              {{ block.settings.title | escape }}
            </div>
          {% endif %}
        </{{ card_tag }}>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .raven-categories {
    --raven-font-heading: "Noto Serif", ui-serif, Georgia, "Times New Roman", Times, serif;
    --raven-font-body: "Noto Sans", ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, Arial, sans-serif;
  }

  .raven-categories__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 32px;
  }

  .raven-categories__heading {
    margin: 0;
    color: rgb(var(--color-foreground-heading-rgb, 15 23 42));
    font-family: var(--raven-font-heading);
    font-weight: 700;
    font-size: 30px;
    line-height: 36px;
  }

  .raven-categories__view-all {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    text-decoration: none;
    color: var(--rcat-link-color);
    font-family: var(--raven-font-body);
    font-weight: 700;
    font-size: 16px;
    line-height: 24px;
    white-space: nowrap;
  }

  .raven-categories__view-all[aria-disabled='true'] {
    opacity: 0.6;
    pointer-events: none;
  }

  .raven-categories__view-all-icon,
  .raven-categories__view-all-icon svg {
    width: 10px;
    height: 10px;
  }

  .raven-categories__grid {
    display: grid;
    gap: var(--rcat-gap);
    grid-template-columns: 1fr;
  }

  @media screen and (min-width: 750px) {
    .raven-categories__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (min-width: 990px) {
    .raven-categories__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  .raven-categories__card {
    display: flex;
    flex-direction: column;
    gap: var(--rcat-card-gap);
    text-decoration: none;
    color: inherit;
  }

  .raven-categories__media {
    position: relative;
    border-radius: var(--rcat-radius);
    overflow: clip;
    width: 100%;
    height: var(--rcat-image-height);
    background: var(--rcat-image-surface);
  }

  .raven-categories__media-surface {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: var(--rcat-image-surface);
  }

  .raven-categories__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .raven-categories__overlay {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: var(--rcat-image-overlay);
  }

  .raven-categories__title {
    text-align: center;
    color: var(--rcat-title-color);
    font-family: var(--raven-font-heading);
    font-weight: 700;
    font-size: 18px;
    line-height: 28px;
  }

  @media screen and (max-width: 749px) {
    .raven-categories__header {
      flex-direction: column;
      align-items: flex-start;
      margin-bottom: 24px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Raven Categories",
  "tag": "section",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "sUdforsk Kategorier"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show “View all” link",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all label",
      "default": "Se alle",
      "visible_if": "{{ section.settings.show_view_all }}"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View all link",
      "visible_if": "{{ section.settings.show_view_all }}"
    },
    {
      "type": "header",
      "content": "Grid"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Gap between cards",
      "min": 0,
      "max": 64,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Gap between image and title",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Image corner radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "image_height",
      "label": "Image height",
      "min": 160,
      "max": 520,
      "step": 4,
      "unit": "px",
      "default": 260
    },
    {
      "type": "header",
      "content": "Image overlay"
    },
    {
      "type": "checkbox",
      "id": "enable_image_overlay",
      "label": "Enable image overlay",
      "default": true
    },
    {
      "type": "color",
      "id": "image_surface",
      "label": "Image surface color",
      "alpha": true,
      "default": "rgba(71,19,174,0.10)"
    },
    {
      "type": "color",
      "id": "image_overlay",
      "label": "Overlay color",
      "alpha": true,
      "default": "rgba(0,0,0,0.10)",
      "visible_if": "{{ section.settings.enable_image_overlay }}"
    },
    {
      "type": "header",
      "content": "Text colors"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Category title color",
      "alpha": true,
      "default": "#0F172A"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Header link color",
      "alpha": true,
      "default": "#4713AE"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "Left padding",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "Right padding",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Hudpleje"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Raven Categories",
      "category": "Raven Beauty",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "title": "Hudpleje"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Makeup"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Hårpleje"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Parfume"
          }
        }
      ]
    }
  ]
}
{% endschema %}

